# =========================
# 🔐 ENV FILES (IMPORTANT)
# =========================
.env
.env.*
*.env

# =========================
# 🐍 PYTHON / DJANGO
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.sqlite3
db.sqlite3
*.log

# Virtual environment
venv/
env/
ENV/

# Django static/media (optional)
staticfiles/
media/

# Migrations (optional)
# Remove if you want to keep migrations
**/migrations/*
!**/migrations/__init__.py

